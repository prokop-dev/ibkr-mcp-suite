<configuration>
    <appender name="STDERR" class="ch.qos.logback.core.ConsoleAppender">
        <target>System.err</target>
        <encoder>
            <pattern>%d{HH:mm:ss.SSS} [%thread] %-5level %logger{36} - %msg%n</pattern>
        </encoder>
    </appender>

    <!-- Set root logger to output to STDERR only -->
    <root level="INFO">
        <appender-ref ref="STDERR" />
    </root>

    <!-- You can adjust log levels for specific packages if needed -->
    <!-- <logger name="dev.prokop.ibkr" level="DEBUG" /> -->
</configuration>
